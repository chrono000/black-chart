# ── Black Chart configuration ──
# All optional. Copy to .env.local (dev) or .env.production (build) as needed.

# Dev proxy target. Default: production (api.hollaex.com). Set to "sandbox" for test funds.
# VITE_HOLLAEX_ENV=sandbox

# Static-deploy API base (no Vite proxy). Same-origin proxy path or full HollaEx base.
# VITE_API_URL=https://api.hollaex.com/v2

# Static-deploy WebSocket stream URL.
# VITE_WS_URL=wss://api.hollaex.com/stream

# Boot straight into paper trading (for an embed/demo build). Same as ?paper=1.
# VITE_START_MODE=paper
